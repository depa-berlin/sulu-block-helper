{
    "name": "depa/sulu-block-helper",
    "description": "Shared XML fragments, Twig partials and Helper for Sulu block bundles",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^7.0",
        "symfony/intl": "^7.0",
        "twig/twig": "^3.0",
        "lubomirfiala/sulu-preview-nav": "^0.1.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Depa\\SuluBlockHelperBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Depa\\SuluBlockHelperBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
